generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnonUser {
  id        String     @id
  createdAt DateTime   @default(now())
  lastSeen  DateTime   @default(now())
  account   Account?
  games     Game[]
  reactions Reaction[]
}

model Account {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  displayName   String?
  primaryAnonId String        @unique
  primaryAnon   AnonUser      @relation(fields: [primaryAnonId], references: [id])
  sessions      AuthSession[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([createdAt])
}

model AuthSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([expiresAt])
}

model Game {
  id           String     @id @default(cuid())
  ownerId      String
  owner        AnonUser   @relation(fields: [ownerId], references: [id])
  title        String     @default("Untitled")
  summary      String?    @db.Text
  genre        String?
  tags         String[]   @default([])
  controls     String[]   @default([])
  coverPrompt  String?    @db.Text
  coverUrl     String?
  status       GameStatus @default(DRAFT)
  visibility   Visibility @default(PUBLIC)
  contentType  ContentType @default(GAME)
  playUrl      String?
  sourceUrl    String?
  version      Int        @default(1)
  parentGameId String?
  parent       Game?      @relation("Remix", fields: [parentGameId], references: [id])
  remixes      Game[]     @relation("Remix")
  playCount    Int        @default(0)
  likeCount    Int        @default(0)
  messages     Message[]
  jobs         Job[]
  reactions    Reaction[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([visibility, createdAt])
  @@index([contentType, visibility, createdAt])
  @@index([ownerId, createdAt])
}

enum GameStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum ContentType {
  GAME
  APPLICATION
}

model Message {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  role      Role
  content   String   @db.Text
  jobId     String?
  createdAt DateTime @default(now())

  @@index([gameId, createdAt])
}

enum Role {
  USER
  AGENT
  SYSTEM
}

model Job {
  id          String    @id @default(cuid())
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id])
  status      JobStatus @default(QUEUED)
  modelKey    String    @default("standard") @db.VarChar(32)
  skeletonKey String    @default("auto") @db.VarChar(32)
  progress    Int       @default(0)
  sandboxId   String?
  prompt      String    @db.Text
  log         String?   @db.Text
  sourceUrl   String?   @db.Text
  useContinue Boolean  @default(false)
  errorMsg    String?   @db.Text
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([gameId, createdAt])
}

enum JobStatus {
  QUEUED
  RUNNING
  VALIDATING
  REPAIRING
  FINISHING
  DONE
  FAILED
}

model Reaction {
  id        String       @id @default(cuid())
  gameId    String
  game      Game         @relation(fields: [gameId], references: [id])
  anonId    String
  anon      AnonUser     @relation(fields: [anonId], references: [id])
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([gameId, anonId, type])
}

enum ReactionType {
  LIKE
}

model UsageBucket {
  id          String   @id @default(cuid())
  key         String
  count       Int      @default(0)
  windowStart DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
}
